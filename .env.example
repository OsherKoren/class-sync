# Database — Neon Postgres (https://neon.tech)
DATABASE_URL=postgresql://user:password@host/database

# NextAuth
NEXTAUTH_SECRET=replace-with-random-secret
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — Google Cloud Console
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# Redis — Upstash (https://upstash.com) for rate limiting and web push subscription storage
UPSTASH_REDIS_REST_URL=replace-with-upstash-redis-rest-url
UPSTASH_REDIS_REST_TOKEN=replace-with-upstash-redis-rest-token

# Web Push VAPID keys — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_KEY=replace-with-vapid-public-key
VAPID_PRIVATE_KEY=replace-with-vapid-private-key
VAPID_SUBJECT=mailto:your-email@example.com
